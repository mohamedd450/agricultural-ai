# ─────────────────────────────────────────────────────────────
# Agricultural AI Platform – Frontend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Backend API base URL
REACT_APP_API_URL=http://localhost:8000/api/v1

# WebSocket URL for real-time updates
REACT_APP_WS_URL=ws://localhost:8000/ws

# Default interface language ("ar" or "en")
REACT_APP_DEFAULT_LANGUAGE=ar

# Enable/disable debug mode
REACT_APP_DEBUG=false

# Maximum image upload size in MB
REACT_APP_MAX_IMAGE_SIZE_MB=10

# App title (overrides default)
REACT_APP_TITLE=Agricultural AI Platform
