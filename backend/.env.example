# ─────────────────────────────────────────────────────────────
# Agricultural AI Platform – Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────
APP_NAME="Agricultural AI Platform"
DEBUG=false
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ── Authentication / JWT ──────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Qdrant (vector DB) ────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=agricultural_embeddings

# ── EdgeQuake (Graph-RAG) ─────────────────────────────────────
EDGEQUAKE_ENDPOINT=http://localhost:8081/edgequake

# ── LLM (OpenAI-compatible) ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Optional: override base URL for alternative providers
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Speech / Vision models ────────────────────────────────────
WHISPER_MODEL_SIZE=base
VISION_MODEL_NAME=efficientnet_b0

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Observability ─────────────────────────────────────────────
PROMETHEUS_ENABLED=true
