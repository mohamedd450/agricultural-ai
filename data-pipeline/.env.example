# ─────────────────────────────────────────────────────────────
# Agricultural AI Platform – Data Pipeline Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Qdrant (vector store) ─────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=agricultural_knowledge

# ── Neo4j (knowledge graph) ───────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Embedding model ───────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Pipeline settings ─────────────────────────────────────────
# Primary language of source documents: "ar" (Arabic) or "en" (English)
PIPELINE_LANGUAGE=ar

# Text chunk target character length
CHUNK_SIZE=512

# Overlap between consecutive chunks
CHUNK_OVERLAP=50

# Number of texts per embedding batch
EMBED_BATCH_SIZE=32

# Enable OCR for scanned PDFs (requires tesseract)
OCR_ENABLED=true
